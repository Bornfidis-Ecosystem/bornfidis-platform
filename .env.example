# App Configuration
# Local: http://localhost:3000 | Production: https://platform.bornfidis.com (ops live on platform subdomain per DNS guardrails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional: used as fallback for invite links (Phase 2B-Email)
NEXT_PUBLIC_APP_URL=https://platform.bornfidis.com
NEXT_PUBLIC_SITE_NAME=Bornfidis Provisions

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: log every SQL query in dev (default off — Prisma still logs errors/warnings)
# PRISMA_LOG_QUERIES=1

# Database (Prisma) — required for build and runtime
# Supabase: Settings → Database → Connection string (direct for DATABASE_URL; use pooler port 6543 for runtime if preferred)
# If you see "MaxClientsInSessionMode" / pool exhausted in dev: use Transaction pooler (6543 + pgbouncer=true) for DATABASE_URL,
# or reduce parallel load (admin dashboard no longer self-fetches four API routes in parallel).
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# Email Configuration (Resend)
# Get API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
ADMIN_EMAIL=bornfidisprovisions@gmail.com

# Admin Authentication (Temporary - Phase 1)
# Change this to a secure password
ADMIN_PASSWORD=strong-password-here

# Email From Address (optional - defaults to Resend test domain)
# Production: Bornfidis <noreply@bornfidis.com> (verify domain in Resend)
RESEND_FROM_EMAIL=Bornfidis <noreply@bornfidis.com>
# Optional reply-to for transactional mail (e.g. AI quote HTML in `lib/quote-email.ts`)
# RESEND_REPLY_TO=hello@bornfidis.com

# Anthropic — AI quote agent (`lib/anthropic-quote-agent.ts`)
# ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_QUOTE_MODEL=claude-sonnet-4-20250514

# AI quote generation — pricing context (`lib/quote-generate-context.ts`, optional overrides)
# PRICING_BASE_PER_GUEST=45
# PRICING_PRODUCE_PER_GUEST=18
# PRICING_EQUIPMENT_FLAT=150
# PRICING_TRAVEL_PER_MILE=1.2
# PRICING_TAX_RATE=0
# Default day rate passed to the model for Prisma `User` chefs (no rate column on User)
# PRICING_CHEF_DAY_RATE_DEFAULT=450

# Quote review mode: set to `false` to save draft + skip auto-email; admin sends via POST /api/admin/quotes/[quoteId]/send
# QUOTE_AUTO_SEND=true

# Phase 2: Instant booking inquiry email — WhatsApp link for time-sensitive follow-up (full URL)
# BOOKING_INQUIRY_WA_ME_URL=https://wa.me/18027335348

# Homepage — TikTok (optional). Handle without @. Video IDs = numeric id from each video URL (/video/123…).
# If NEXT_PUBLIC_TIKTOK_HANDLE is unset, the TikTok section is hidden.
# NEXT_PUBLIC_TIKTOK_HANDLE=bornfidis.provisions
# NEXT_PUBLIC_TIKTOK_VIDEO_IDS=7123456789012345678,7123456789012345679

# Phase 2B: Admin Authentication
# Comma-separated list of allowed admin email addresses
# Example: ADMIN_EMAILS=bornfidisprovisions@gmail.com,admin2@example.com
ADMIN_EMAILS=bornfidisprovisions@gmail.com

# Phase 2Q: Chef payout performance bonuses (set false to disable globally)
# ENABLE_CHEF_PAYOUT_BONUSES=true

# Phase 2S: Tiered chef rates — Pro +10%, Elite +20% (set false to disable globally)
# ENABLE_CHEF_TIERED_RATES=true

# Required for `/api/cron/*` routes (prep-reminders, SLA, currency-rates, leaderboard, statements, etc.).
# Set the same value in Vercel → Production (and Preview if you use cron there). Vercel injects
# `Authorization: Bearer <CRON_SECRET>` on scheduled invocations when this env var exists.
# Local/manual: `curl -H "Authorization: Bearer <same value>" http://localhost:3000/api/cron/prep-reminders`
# Also protects `/api/cron/balance-reminders` (deposit paid, balance due, event within 3 days, 7-day reminder cooldown).
# Optional fallback: requests with User-Agent containing `vercel-cron` are allowed if CRON_SECRET is set.
# CRON_SECRET=generate-a-long-random-string-at-least-16-chars

# Phase 2AC: Chef earnings projections (set to false to disable estimates globally)
# EARNINGS_PROJECTIONS_ENABLED=false

# Phase 2AI: Multi-currency payouts (set true to allow chefs to choose JMD, EUR, GBP)
# NON_USD_PAYOUTS_ENABLED=false
# Optional: ExchangeRate-API key for daily FX cron (https://www.exchangerate-api.com/). If unset, fallback rates used.
# EXCHANGE_RATE_API_KEY=

# Phase 2AJ: SLA alerts (optional overrides; defaults in code)
# SLA_ASSIGNMENT_HOURS=24
# SLA_CONFIRMATION_HOURS=48
# SLA_ARRIVAL_GRACE_MINUTES=15
# SLA_ESCALATION_WINDOW_HOURS=4
# SLA_QUIET_START_HOUR=22
# SLA_QUIET_END_HOUR=7
# OPS_LEAD_EMAIL=ops@example.com

# Phase 2AK: Web Push (PWA). Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Phase 2AL: Region pricing (set false to disable; defaults to 1.0 multiplier, no travel/minimum)
# ENABLE_REGION_PRICING=true

# Phase 2AM: SMS fallback for critical alerts (set false to disable)
# SMS_FALLBACK_ENABLED=true
# SMS_FALLBACK_MAX_PER_DAY=5

# Phase 2AN: Surge pricing (set false to disable globally)
# ENABLE_SURGE_PRICING=true

# Stripe (Passive Income / Checkout)
# Test keys: sk_test_... / pk_test_... | Live: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Webhook signing secret (from Stripe Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Fixed one-time Prices (Dashboard → Products) for POST /api/checkout modes `deposit` and `consulting`
# Balance uses dynamic price_data in code — no Price ID required.
# STRIPE_DEPOSIT_PRICE_ID=price_xxxx
# STRIPE_CONSULT_PRICE_ID=price_xxxx
# Base URL for checkout success/cancel redirects (e.g. https://platform.bornfidis.com or http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional: Stripe Price IDs for passive income products (create in Stripe Dashboard → Products → Add price)
# NEXT_PUBLIC_STRIPE_PRICE_PRICING_CALCULATOR=price_xxxx
# NEXT_PUBLIC_STRIPE_PRICE_ORDER_AGREEMENT=price_xxxx

# Academy webhook (separate endpoint): add in Stripe Dashboard → Webhooks → URL /api/webhooks/academy, event checkout.session.completed
STRIPE_ACADEMY_WEBHOOK_SECRET=whsec_xxxx

# Academy manuals — create Products in Stripe Dashboard, then one-time Price (USD), copy Price ID here:
# Regenerative Enterprise Foundations™ $39
NEXT_PUBLIC_STRIPE_ACADEMY_REGENERATIVE_ENTERPRISE=price
NEXT_PUBLIC_STRIPE_ACADEMY_REGENERATIVE_FARMER=price
# Vermont Contractor Foundations™ $49
NEXT_PUBLIC_STRIPE_ACADEMY_VERMONT_CONTRACTOR=price_
# Jamaican Chef Enterprise System™ $79

# Other Academy products (optional)
# NEXT_PUBLIC_STRIPE_ACADEMY_LLC_STARTER=price_xxxx
