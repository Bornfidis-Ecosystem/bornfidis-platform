generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model Farmer {
  id                        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt                 DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  name                      String
  phone                     String        @unique
  whatsapp_number           String?
  location                  String?
  parish                    String?       @default("Portland")
  farm_name                 String?
  crops_available           String[]
  farm_size_acres           Decimal?      @db.Decimal
  preferred_collection_day  String?
  typical_weekly_volume_lbs Decimal?      @db.Decimal
  quality_rating            Int?
  reliability_rating        Int?
  price_list                Json?
  payment_terms             String?
  farmer_status             String?       @default("inquiry")
  onboarding_completed      Boolean?      @default(false)
  last_delivery_date        DateTime?     @db.Date
  notes                     String?
  source                    String?       @default("whatsapp")
  tags                      String[]
  farmListings              FarmListing[]

  @@index([phone], map: "idx_farmers_phone")
  @@index([farmer_status], map: "idx_farmers_status")
  @@map("farmers")
  @@schema("public")
}

model FarmerCrop {
  id        String   @id @default(uuid())
  farmerId  String   @map("farmer_id")
  crop      String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([farmerId, crop])
  @@map("farmer_crops")
  @@schema("public")
}

model Intake {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now()) @map("createdAt") @db.Timestamptz(6)
  channel    String
  from       String   @map("from")
  message    String
  farmerName String?  @map("farmerName")
  status     String   @default("new")
  type       String   @default("inquiry")

  @@map("intakes")
  @@schema("public")
}

model FarmerIntake {
  id               String             @id @default(uuid())
  createdAt        DateTime           @default(now()) @map("created_at")
  channel          String             @default("whatsapp")
  fromPhone        String             @map("from_phone")
  messageText      String?            @map("message_text")
  mediaUrl         String?            @map("media_url")
  mediaContentType String?            @map("media_content_type")
  transcript       String?
  extractedJson    Json?              @map("extracted_json")
  farmerId         String?            @map("farmer_id")
  parsedJson       Json?              @map("parsed_json")
  parsedData       Json?              @map("parsed_data")
  status           FarmerIntakeStatus @default(received)
  error            String?

  @@map("farmer_intakes")
  @@schema("public")
}

model WhatsAppMessage {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  phoneNumber String   @map("phone_number")
  messageText String   @map("message_text")
  farmerName  String?  @map("farmer_name")

  @@map("whatsapp_messages")
  @@schema("public")
}

model User {
  id                    String                    @id @default(uuid())
  openId                String?                   @map("open_id")
  name                  String?
  email                 String?
  loginMethod           String?                   @map("login_method")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  lastSignedIn          DateTime?                 @map("last_signed_in")
  role                  UserRole?                 @default(FARMER)
  chefAssignments       ChefAssignment[]
  chefAvailabilities    ChefAvailability[]
  chefCalendarToken     ChefCalendarToken?
  chefFeature           ChefFeature?
  leaderboardExclusion  ChefLeaderboardExclusion?
  chefPrepChecklists    ChefPrepChecklist[]
  chefProfile           ChefProfile?
  chefTimeSlots         ChefTimeSlot[]
  coachingCasesAsCoach  CoachingCase[]            @relation("CoachingCaseCoach")
  coachingCasesAsChef   CoachingCase[]            @relation("CoachingCaseChef")
  educationProgress     EducationProgress[]
  incidentsAsChef       Incident[]
  leaderboardSnapshot   LeaderboardSnapshot?
  marginOverrideLogs    MarginOverrideLog[]
  partnerProfile        PartnerProfile?
  pushSubscriptions     PushSubscription[]
  successionAssignments SuccessionAssignment[]
  userBadges            UserBadge[]

  @@map("users")
  @@schema("public")
}

model Invite {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole
  token     String   @unique
  invitedBy String   @map("invited_by")
  accepted  Boolean  @default(false)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email], map: "idx_invites_email")
  @@index([expiresAt], map: "idx_invites_expires_at")
  @@index([token], map: "idx_invites_token")
  @@map("invites")
  @@schema("public")
}

model PartnerProfile {
  id          String      @id @default(cuid())
  userId      String      @unique @map("user_id")
  displayName String      @map("display_name")
  partnerType PartnerType @map("partner_type")
  parish      String?
  phone       String?
  bio         String?
  completed   Boolean     @default(false)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_partner_profiles_user_id")
  @@map("partner_profiles")
  @@schema("public")
}

model Submission {
  id         String   @id @default(uuid())
  type       String?
  name       String?
  phone      String?
  email      String?
  location   String?
  acres      Float?
  crops      String?
  experience String?
  language   String?
  wasOffline Boolean? @default(false) @map("was_offline")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("submissions")
  @@schema("public")
}

model Phase {
  id          String  @id @default(uuid())
  number      Int?
  title       String?
  description String?
  startMonth  String? @map("start_month")
  endMonth    String? @map("end_month")
  status      String?
  months      Month[]

  @@map("phases")
  @@schema("public")
}

model Month {
  id           String        @id @default(uuid())
  phaseId      String?       @map("phase_id")
  number       Int?
  title        String?
  objectives   String?
  status       String?
  deliverables Deliverable[]
  metrics      Metric[]
  phase        Phase?        @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@map("months")
  @@schema("public")
}

model Deliverable {
  id          String   @id @default(uuid())
  monthId     String?  @map("month_id")
  title       String?
  description String?
  completed   Boolean? @default(false)
  month       Month?   @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@map("deliverables")
  @@schema("public")
}

model Metric {
  id      String  @id @default(uuid())
  monthId String? @map("month_id")
  name    String?
  target  Float?
  actual  Float?
  unit    String?
  month   Month?  @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@map("metrics")
  @@schema("public")
}

model BookingInquiry {
  id                           String              @id @default(uuid())
  createdAt                    DateTime            @default(now()) @map("created_at")
  updatedAt                    DateTime?           @updatedAt @map("updated_at")
  name                         String
  email                        String?
  phone                        String?
  whatsapp                     String?
  preferredContact             String?             @map("preferred_contact")
  eventType                    String?             @map("event_type")
  eventDate                    DateTime            @map("event_date") @db.Date
  eventTime                    String?             @map("event_time")
  location                     String
  locationCity                 String?             @map("location_city")
  locationState                String?             @map("location_state")
  guests                       Int?
  budgetRange                  String?             @map("budget_range")
  dietary                      String?
  dietaryRestrictions          String?             @map("dietary_restrictions")
  menuPreferences              String?             @map("menu_preferences")
  specialRequests              String?             @map("special_requests")
  notes                        String?
  status                       String              @default("New")
  statusUpdatedAt              DateTime?           @map("status_updated_at")
  followUpDate                 DateTime?           @map("follow_up_date") @db.Date
  adminNotes                   String?             @map("admin_notes")
  internalNotes                String?             @map("internal_notes")
  quoteCurrency                String?             @map("quote_currency")
  quoteSubtotalCents           Int?                @default(0) @map("quote_subtotal_cents")
  quoteTaxCents                Int?                @default(0) @map("quote_tax_cents")
  quoteTotalCents              Int?                @default(0) @map("quote_total_cents")
  quoteDepositCents            Int?                @default(0) @map("quote_deposit_cents")
  quoteSentAt                  DateTime?           @map("quote_sent_at")
  stripePaymentLinkUrl         String?             @map("stripe_payment_link_url")
  stripeInvoiceId              String?             @map("stripe_invoice_id")
  stripePaymentStatus          String?             @map("stripe_payment_status")
  quotePdfUrl                  String?             @map("quote_pdf_url")
  stripeSessionId              String?             @map("stripe_session_id")
  stripePaymentIntentId        String?             @map("stripe_payment_intent_id")
  depositAmountCents           Int?                @map("deposit_amount_cents")
  paidAt                       DateTime?           @map("paid_at")
  quoteStatus                  String?             @map("quote_status")
  quoteNotes                   String?             @map("quote_notes")
  depositPercent               Int?                @default(30) @map("deposit_percent")
  subtotalCents                Int?                @default(0) @map("subtotal_cents")
  taxCents                     Int?                @default(0) @map("tax_cents")
  serviceFeeCents              Int?                @default(0) @map("service_fee_cents")
  totalCents                   Int?                @default(0) @map("total_cents")
  balanceSessionId             String?             @map("balance_session_id")
  balancePaymentIntentId       String?             @map("balance_payment_intent_id")
  balancePaidAt                DateTime?           @map("balance_paid_at")
  balanceAmountCents           Int?                @default(0) @map("balance_amount_cents")
  fullyPaidAt                  DateTime?           @map("fully_paid_at")
  quoteUpdatedAt               DateTime?           @map("quote_updated_at")
  quoteServiceFeeCents         Int?                @default(0) @map("quote_service_fee_cents")
  depositPercentage            Int?                @default(30) @map("deposit_percentage")
  quoteLineItems               Json?               @default("[]") @map("quote_line_items")
  customerPortalToken          String?             @map("customer_portal_token")
  customerPortalTokenCreatedAt DateTime?           @map("customer_portal_token_created_at")
  customerPortalTokenRevokedAt DateTime?           @map("customer_portal_token_revoked_at")
  assignedChefId               String?             @map("assigned_chef_id")
  chefPayoutAmountCents        Int?                @map("chef_payout_amount_cents")
  chefPayoutStatus             String?             @default("not_applicable") @map("chef_payout_status")
  chefPayoutBlockers           String[]            @map("chef_payout_blockers")
  chefPayoutPaidAt             DateTime?           @map("chef_payout_paid_at")
  stripeTransferId             String?             @map("stripe_transfer_id")
  jobCompletedAt               DateTime?           @map("job_completed_at")
  jobCompletedBy               String?             @map("job_completed_by")
  payoutHold                   Boolean?            @default(false) @map("payout_hold")
  payoutHoldReason             String?             @map("payout_hold_reason")
  payoutReleasedAt             DateTime?           @map("payout_released_at")
  referralSource               String?             @map("referral_source")
  utmSource                    String?             @map("utm_source")
  utmCampaign                  String?             @map("utm_campaign")
  chefPayoutBaseCents          Int?                @map("chef_payout_base_cents")
  chefPayoutBonusCents         Int?                @map("chef_payout_bonus_cents")
  chefPayoutBonusBreakdown     Json?               @map("chef_payout_bonus_breakdown")
  chefPayoutBonusOverride      Boolean?            @default(false) @map("chef_payout_bonus_override")
  chefTierSnapshot             String?             @map("chef_tier_snapshot")
  chefRateMultiplier           Decimal?            @map("chef_rate_multiplier") @db.Decimal(4, 2)
  regionCode                   String?             @map("region_code")
  regionMultiplierSnapshot     Float?              @map("region_multiplier_snapshot")
  regionTravelFeeCentsSnapshot Int?                @map("region_travel_fee_cents_snapshot")
  regionMinimumCentsSnapshot   Int?                @map("region_minimum_cents_snapshot")
  assignedFarmers              BookingFarmer[]
  prepItems                    BookingPrepItem[]
  timeline                     BookingTimeline[]
  chefAssignment               ChefAssignment?
  chefPrepChecklist            ChefPrepChecklist?
  farmerPayouts                FarmerPayout[]
  incidents                    Incident[]
  marginOverrideLogs           MarginOverrideLog[]

  @@map("booking_inquiries")
  @@schema("public")
}

model ChefAvailability {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  chefId    String   @map("chef_id")
  date      DateTime @db.Date
  available Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chef      User     @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([chefId, date])
  @@index([chefId], map: "idx_chef_availabilities_chef_id")
  @@index([date], map: "idx_chef_availabilities_date")
  @@map("chef_availabilities")
  @@schema("public")
}

model ChefTimeSlot {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  chefId    String   @map("chef_id")
  date      DateTime @db.Date
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  available Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chef      User     @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chefId, date], map: "idx_chef_time_slots_chef_date")
  @@map("chef_time_slots")
  @@schema("public")
}

model ChefProfile {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String    @unique @map("user_id")
  tier         ChefTier  @default(STANDARD)
  tierOverride ChefTier? @map("tier_override")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_chef_profiles_user_id")
  @@map("chef_profiles")
  @@schema("public")
}

model ChefFeature {
  chefId        String   @id @map("chef_id")
  featured      Boolean  @default(false)
  adminOverride Boolean  @default(false) @map("admin_override")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  chef          User     @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chef_features")
  @@schema("public")
}

model CoachingCase {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  chefId          String    @map("chef_id")
  reason          String
  status          String
  dueAt           DateTime? @map("due_at") @db.Timestamptz(6)
  assignedCoachId String?   @map("assigned_coach_id")
  actionPlanNote  String?   @map("action_plan_note")
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  coach           User?     @relation("CoachingCaseCoach", fields: [assignedCoachId], references: [id], onUpdate: NoAction)
  chef            User      @relation("CoachingCaseChef", fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chefId], map: "idx_coaching_cases_chef_id")
  @@index([status], map: "idx_coaching_cases_status")
  @@map("coaching_cases")
  @@schema("public")
}

model LeaderboardSnapshot {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  chefId        String   @unique(map: "idx_leaderboard_snapshots_chef_id") @map("chef_id")
  rank          Int
  score         Float
  ratingPct     Float    @map("rating_pct")
  onTimePct     Float    @map("on_time_pct")
  prepPct       Float    @map("prep_pct")
  jobsPct       Float    @map("jobs_pct")
  jobsCompleted Int      @map("jobs_completed")
  periodStart   DateTime @map("period_start") @db.Date
  periodEnd     DateTime @map("period_end") @db.Date
  calculatedAt  DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)
  chef          User     @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([calculatedAt], map: "idx_leaderboard_snapshots_calculated_at")
  @@index([rank], map: "idx_leaderboard_snapshots_rank")
  @@map("leaderboard_snapshots")
  @@schema("public")
}

model ChefLeaderboardExclusion {
  chefId     String    @id @map("chef_id")
  excluded   Boolean   @default(false)
  excludedAt DateTime? @map("excluded_at") @db.Timestamptz(6)
  excludedBy String?   @map("excluded_by")
  chef       User      @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chef_leaderboard_exclusions")
  @@schema("public")
}

model ChefCalendarToken {
  chefId    String   @id @map("chef_id")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chef      User     @relation(fields: [chefId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chef_calendar_tokens")
  @@schema("public")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_push_subscriptions_user_id")
  @@map("push_subscriptions")
  @@schema("public")
}

model RegionPricing {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  regionCode     String   @unique @map("region_code")
  name           String?
  zone           String?
  multiplier     Float    @default(1.0)
  travelFeeCents Int      @default(0) @map("travel_fee_cents")
  minimumCents   Int      @default(0) @map("minimum_cents")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([enabled], map: "idx_region_pricing_enabled")
  @@index([regionCode], map: "idx_region_pricing_region_code")
  @@map("region_pricing")
  @@schema("public")
}

model Incident {
  id            String          @id @default(cuid())
  type          String
  severity      String
  summary       String
  impact        String?
  root_cause    String?
  whatWentWell  String?         @map("what_went_well")
  whatToImprove String?         @map("what_to_improve")
  actions       Json?
  closedAt      DateTime?       @map("closed_at") @db.Timestamptz(6)
  bookingId     String?         @map("booking_id")
  chefId        String?         @map("chef_id")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  booking       BookingInquiry? @relation(fields: [bookingId], references: [id], onUpdate: NoAction)
  chef          User?           @relation(fields: [chefId], references: [id], onUpdate: NoAction)

  @@index([bookingId], map: "idx_incidents_booking_id")
  @@index([chefId], map: "idx_incidents_chef_id")
  @@index([createdAt(sort: Desc)], map: "idx_incidents_created_at")
  @@index([severity], map: "idx_incidents_severity")
  @@map("incidents")
  @@schema("public")
}

model ImprovementItem {
  id          String    @id @default(cuid())
  source      String
  title       String
  impact      String
  effort      String
  urgency     String    @default("Medium")
  owner       String?
  status      String    @default("Backlog")
  outcomeNote String?   @map("outcome_note")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_improvement_items_created_at")
  @@index([status], map: "idx_improvement_items_status")
  @@map("improvement_items")
  @@schema("public")
}

model MarginGuardrailConfig {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  regionCode          String?  @unique @map("region_code")
  minGrossMarginPct   Decimal  @default(25) @map("min_gross_margin_pct") @db.Decimal
  maxBonusPlusTierPct Decimal  @default(20) @map("max_bonus_plus_tier_pct") @db.Decimal
  maxSurgeMultiplier  Decimal? @map("max_surge_multiplier") @db.Decimal
  minJobValueCents    Int?     @map("min_job_value_cents")
  blockOrWarn         Boolean  @default(true) @map("block_or_warn")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([regionCode], map: "idx_margin_guardrail_config_region")
  @@map("margin_guardrail_config")
  @@schema("public")
}

model MarginOverrideLog {
  id        String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  bookingId String         @map("booking_id")
  userId    String         @map("user_id")
  action    String
  reason    String?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  booking   BookingInquiry @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bookingId], map: "idx_margin_override_log_booking")
  @@index([userId], map: "idx_margin_override_log_user")
  @@map("margin_override_log")
  @@schema("public")
}

model Okr {
  id         String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  period     String
  objective  String
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  keyResults KeyResult[]

  @@index([period], map: "idx_okrs_period")
  @@map("okrs")
  @@schema("public")
}

model KeyResult {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  okrId     String   @map("okr_id")
  metric    String
  target    Decimal  @db.Decimal
  current   Decimal  @default(0) @db.Decimal
  notes     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  okr       Okr      @relation(fields: [okrId], references: [id], onDelete: Cascade, onUpdate: NoAction)

