  payment_status   String?    @default("pending")
  payment_date     DateTime   @db.Date
  reference_number String?
  receipt_url      String?
  notes            String?
  processed_by     String?
  bookings         bookings?  @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers        customers? @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([booking_id], map: "idx_payments_booking_id")
  @@index([customer_id], map: "idx_payments_customer_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quotes {
  id                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at         DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?       @default(now()) @db.Timestamptz(6)
  booking_id         String?         @db.Uuid
  version            Int?            @default(1)
  service_type       String
  subtotal_usd       Decimal         @db.Decimal(10, 2)
  tax_usd            Decimal?        @default(0) @db.Decimal(10, 2)
  discount_usd       Decimal?        @default(0) @db.Decimal(10, 2)
  total_usd          Decimal         @db.Decimal(10, 2)
  quote_status       String?         @default("draft")
  sent_date          DateTime?       @db.Date
  accepted_date      DateTime?       @db.Date
  expires_date       DateTime?       @db.Date
  deposit_percentage Int?            @default(50)
  deposit_amount_usd Decimal?        @db.Decimal(10, 2)
  payment_terms      String?
  notes              String?
  customer_notes     String?
  booking_items      booking_items[]
  bookings           bookings?       @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([booking_id], map: "idx_quotes_booking_id")
  @@index([quote_status], map: "idx_quotes_status")
  @@schema("public")
}

